const API = 'http://192.168.12.241:3000';
const theme = {
  bg: '#0b0b0d',
  surface: '#1c1c1e',
  surfaceAlt: '#2c2c2e',
  border: '#2e2e30',
  text: '#ffffff',
  textMuted: '#9a9aa0',
